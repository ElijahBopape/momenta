# Populated automatically by `vercel install supabase` (or `vercel env pull`)
# once the project is linked to Vercel and Supabase is provisioned. Do not
# commit the real .env.local — this file just documents what's required.

# Used by the browser and server Supabase clients (src/lib/supabase/*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — privileged access, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# Used by scripts/migrate.mjs to apply supabase/migrations/*.sql directly
POSTGRES_URL_NON_POOLING=

# Optional: overrides the canonical origin used to build auth redirect
# links (src/lib/site-url.ts). Falls back to Vercel's system env vars,
# then localhost. Set this if the Vercel-provided domain isn't the one
# registered in Supabase's Auth redirect allow-list.
NEXT_PUBLIC_SITE_URL=
